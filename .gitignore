# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.log

# ML Models (large binary files — store in DVC or artifact registry)
backend/models/trained/*.pkl

# Uploads & generated reports
backend/uploads/*
backend/reports/*
!backend/uploads/.gitkeep
!backend/reports/.gitkeep

# Database files
*.db
*.sqlite
*.sqlite3

# Environment variables — NEVER commit secrets
.env
.env.local
.env.production
backend/.env

# Node / Frontend
node_modules/
frontend/build/
frontend/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
.dockerignore

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Kubernetes secrets (use sealed-secrets or vault in prod)
k8s/secrets.yaml

# Monitoring data
monitoring/grafana/data/
monitoring/prometheus/data/

# Test artifacts
test_report_*.pdf
backend/test_report_*.pdf
backend/test_landiq.db
